#!/bin/bash
# toggle-hdpi (Dynamic Scaling script for Niri)
# Waybar provides the current output via WAYBAR_OUTPUT_NAME

OUTPUT="${WAYBAR_OUTPUT_NAME}"
# Fallback to focused output if run manually
if [ -z "$OUTPUT" ]; then
    OUTPUT=$(niri msg --json focused-output | jq -r '.name')
fi

CONFIG_FILE="$HOME/.config/niri/config.kdl"

# Extract current scale for this output from config.kdl
CURRENT_SCALE=$(awk -v out="output \"$OUTPUT\" {" '
    $0 ~ out { found=1; next }
    found && /scale / { print $2; exit }
    found && /}/ { print "1.0"; exit }
' "$CONFIG_FILE")

# Default if not found in the block
if [ -z "$CURRENT_SCALE" ]; then
    CURRENT_SCALE="1.0"
fi

if [ "$1" = "--toggle" ]; then
    # Cycle logic
    case "$CURRENT_SCALE" in
        "1.5") NEXT_SCALE="1.25" ;;
        "1.25") NEXT_SCALE="1.0" ;;
        "1.0") NEXT_SCALE="0.75" ;;
        "0.75") NEXT_SCALE="1.5" ;;
        *) NEXT_SCALE="1.5" ;;
    esac

    # Replace the scale line in the specific output block
    sed -i "/output \"$OUTPUT\" {/,/^}/ s/scale .*/scale $NEXT_SCALE/" "$CONFIG_FILE"
    
    # Reload Niri seamlessly
    niri msg action do reload-config >/dev/null 2>&1 || true
    
    CURRENT_SCALE="$NEXT_SCALE"
fi

# Print plain text output for Waybar
echo "󰍹 ${CURRENT_SCALE}x"
