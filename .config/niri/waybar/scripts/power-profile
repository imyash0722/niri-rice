#!/bin/bash
CURRENT=$(powerprofilesctl get)

LOW="🐢"
BALANCED="☯️"
HIGH="🐇"

if [ "$CURRENT" = 'power-saver' ]; then
  if [ "$1" = "--toggle" ]; then
    powerprofilesctl set balanced >/dev/null 2>&1 || true
    pkill -RTMIN+9 waybar
    echo $BALANCED; exit 0
  fi
  echo $LOW
elif [ "$CURRENT" = 'balanced' ]; then
  if [ "$1" = "--toggle" ]; then
    powerprofilesctl set performance >/dev/null 2>&1 || true
    pkill -RTMIN+9 waybar
    echo $HIGH; exit 0
  fi
  echo $BALANCED
elif [ "$CURRENT" = 'performance' ]; then
  if [ "$1" = "--toggle" ]; then
    powerprofilesctl set power-saver >/dev/null 2>&1 || true
    pkill -RTMIN+9 waybar
    echo $LOW; exit 0
  fi
  echo $HIGH
else
  # Fallback if powerprofilesctl fails or is not installed
  echo $BALANCED
fi


