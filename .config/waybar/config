{
  "spacing": 4,
  "bar_id": "bar-0",
  "ipc": true,
  "hidden_state": "show",
  "modules-left": [
    "clock",
    "mpris",
    "custom/updates"
  ],
  "modules-center": [
    "niri/workspaces"
  ],
  "modules-right": [
    "tray",
    "custom/dpi",
    "bluetooth",
    "pulseaudio",
    "network",
    "battery"
  ],

  "custom/dpi": {
    "exec": "~/.config/waybar/scripts/toggle-hdpi",
    "on-click": "~/.config/waybar/scripts/toggle-hdpi --toggle",
    "restart-interval": 2
  },
  "clock": {
    "interval": 60,
    "format": "{:%H:%M}",
    "on-click": "gnome-calendar",
    "max-length": 25
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-charging": "σΑ²³",
    "format-plugged": "σΑöΞ",
    "format-icons": [
      "σΑ²é",
      "σΑ¹Φ",
      "σΑ¹Ψ",
      "σΑ²Ä",
      "σΑ¹Ι"
    ],
    "on-click": "foot --app-id=foot.batctl --window-size-chars=81x34 -e sudo batctl"
  },

  "niri/workspaces": {
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": []
    },
    "format": " {index} "
  },
  "network": {
    "format-wifi": "σΑΛ®",
    "on-click": "kcmshell6 kcm_networkmanagement",
    "format-ethernet": "σΑàÄ   {ipaddr}/{cidr}",
    "format-linked": "σΑàÄ   {ifname} (No IP)",
    "format-disconnected": "σ±öΒ   Disconnected",
    "tooltip-format": "{ifname} via {gwaddr}"
  },
  "bluetooth": {
    "format": "σΑ²·",
    "format-disabled": "σΑ²≤",
    "format-connected": "σΑ²±",
    "format-connected-battery": "σΑ²±",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "kcmshell6 kcm_bluetooth"
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}σΑ²· {format_source}",
    "format-bluetooth-muted": " {icon}σΑ²· {format_source}",
    "format-muted": "σΑùü {format_source}",
    "format-source": "{volume}% σΑç§",
    "format-source-muted": "σΑç≠",
    "format-icons": {
      "headphone": "σΑ΄΄",
      "hands-free": "σΑΞΑ",
      "headset": "σΑ΄é",
      "phone": "σΑè≤",
      "portable": "σΑè≤",
      "car": "σΑ³΄",
      "default": [
        "σΑïΩ",
        "σΑ•Ä",
        "σΑïΨ"
      ]
    },
    "on-right-click": "~/.config/waybar/scripts/mic-toggle --toggle",
    "on-middle-click": "nautilus /home/pineapple",
    "on-click": "kcmshell6 kcm_pulseaudio"
  },
  "custom/updates": {
    "exec": "~/.config/waybar/scripts/check-updates",
    "interval": 3600, // 3600 seconds = 1 hour
    "return-type": "json",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/check-updates update"
  },
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
     "title-len": 32,
     "album-len": 0,
     "artist-len": 0,
    "player-icons": {
      "default": "βèΗ",
      "mpv": "πüéΒ"
    },
    "status-icons": {
      "paused": "β•Ε"
    }
  },
  "tray": {
    "icon-size": 16,
    "spacing": 0
  }
}
